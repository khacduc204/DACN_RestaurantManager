@model KD_Restaurant.ViewModels.StoreLocatorViewModel
@using System.Text.Json
@using System.Linq
@{
    ViewData["Title"] = Model.PageTitle;
    var branchJson = JsonSerializer.Serialize(Model.Branches, new JsonSerializerOptions
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
        WriteIndented = false
    });
}

@section Styles {
    <style>
        .store-page {
            margin-top: 7.5rem;
        }

        .store-hero {
            background: linear-gradient(135deg, rgba(247, 125, 5, 0.95), rgba(241, 58, 70, 0.95));
            color: #fff;
            border-radius: 32px;
            padding: 3rem;
            margin-bottom: 2rem;
            box-shadow: 0 20px 60px rgba(15, 15, 15, 0.25);
        }

        .store-hero h1 {
            font-family: 'Playfair Display', serif;
            font-size: clamp(2rem, 4vw, 3.3rem);
            margin-bottom: 1rem;
        }

        .store-locator {
            background: #fff;
            border-radius: 24px;
            padding: 2rem;
            box-shadow: 0 20px 65px rgba(15, 23, 42, 0.12);
            margin-bottom: 3rem;
        }

        .store-actions {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 1rem;
            margin-top: 1.5rem;
        }

        .store-actions button {
            border-radius: 999px;
            padding: 0.8rem 1.2rem;
            font-weight: 600;
            border: none;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .btn-location {
            background: linear-gradient(135deg, #f97316, #fb923c);
            color: #fff;
        }

        .btn-search {
            background: #fff;
            border: 1px solid rgba(0, 0, 0, 0.08);
        }

        .store-search-box {
            display: flex;
            gap: 0.5rem;
            margin-top: 1rem;
        }

        .store-search-box input {
            flex: 1;
            border-radius: 999px;
            border: 1px solid rgba(0, 0, 0, 0.12);
            padding: 0.85rem 1.2rem;
            font-size: 1rem;
            box-shadow: inset 0 1px 2px rgba(15, 15, 15, 0.06);
        }

        .store-search-box button {
            border-radius: 999px;
            border: none;
            padding: 0.85rem 1.5rem;
            font-weight: 600;
            background: #0f172a;
            color: #fff;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .store-search-box button:hover {
            transform: translateY(-1px);
            box-shadow: 0 12px 30px rgba(15, 23, 42, 0.25);
        }

        .store-map-panel {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 2rem;
            margin-top: 2.5rem;
        }

        .store-map-wrapper {
            border-radius: 24px;
            overflow: hidden;
            border: 1px solid rgba(15, 23, 42, 0.08);
            min-height: 480px;
        }

        #store-map {
                    width: 100%;
                    height: 100%;
                    min-height: 480px;
                }

        .store-alert {
            display: none;
            margin-top: 1.25rem;
            border-radius: 16px;
            padding: 0.9rem 1.2rem;
            font-weight: 500;
        }

        .store-alert.is-info { background: rgba(59, 130, 246, 0.12); color: #1d4ed8; }
        .store-alert.is-error { background: rgba(239, 68, 68, 0.12); color: #b91c1c; }
        .store-alert.is-success { background: rgba(16, 185, 129, 0.12); color: #047857; }
        .store-alert.is-warning { background: rgba(245, 158, 11, 0.15); color: #b45309; }

        .store-branch-list {
            background: #0f172a;
            color: #fff;
            border-radius: 24px;
            padding: 1.75rem;
            box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.08);
        }

        .branch-grid {
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
            max-height: 520px;
            overflow-y: auto;
            padding-right: 0.25rem;
        }

        .branch-card {
            background: rgba(15, 23, 42, 0.55);
            border-radius: 18px;
            padding: 1.1rem 1.2rem;
            border: 1px solid transparent;
            cursor: pointer;
            transition: border-color 0.2s ease, transform 0.2s ease;
        }

        .branch-card.is-nearest {
            border-color: #f97316;
            box-shadow: 0 12px 30px rgba(249, 115, 22, 0.35);
        }

        .branch-card-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .store-empty-state {
            background: rgba(15, 23, 42, 0.15);
            border-radius: 16px;
            padding: 1.25rem;
            color: #0f172a;
            font-weight: 500;
        }

        @@media (max-width: 992px) {
            .store-page { margin-top: 9rem; }
            .store-map-panel { grid-template-columns: 1fr; }
            .store-branch-list { background: #fff; color: #0f172a; box-shadow: 0 12px 30px rgba(15, 23, 42, 0.12); }
            .branch-card { background: #fff; color: #0f172a; }
            .branch-card-actions a { color: #0f172a; }
        }
    </style>
}

<div class="container store-page">
    <div class="store-hero">
        <p class="text-uppercase fw-semibold mb-2" style="letter-spacing: 0.25rem;">KD RESTAURANT</p>
        <h1 class="mb-3">@Model.PageTitle</h1>
        <p>@Model.IntroText</p>
        <div class="store-actions">
            <button id="btn-use-location" type="button" class="btn-location">
                <i class="bi bi-geo-alt-fill me-2"></i>Sử dụng vị trí của tôi
            </button>
            <button id="btn-reset-view" type="button" class="btn-search">
                <i class="bi bi-arrow-counterclockwise me-2"></i>Về trung tâm @Model.DefaultCityName
            </button>
        </div>
    </div>

    <div class="store-locator">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start gap-3">
            <div>
                <h3 class="fw-semibold mb-2">Khám phá chi nhánh KD Restaurant</h3>
                <p class="text-muted mb-0" id="location-status">
                    <i class="bi bi-info-circle me-1"></i>
                    Đang hiển thị trung tâm @Model.DefaultCityName. Bật định vị để xem chi nhánh gần bạn nhất.
                </p>
            </div>
            <div class="w-100 w-lg-auto">
                <div class="store-search-box">
                    <input id="store-search-input" type="text" placeholder="Nhập địa chỉ, phường/xã, quận/huyện...">
                    <button id="btn-search-address" type="button">
                        <i class="bi bi-search me-2"></i>Tìm kiếm
                    </button>
                </div>
            </div>
        </div>

        <div id="store-alert" class="store-alert" role="alert" aria-live="polite"></div>

        <div class="store-map-panel">
            <div class="store-map-wrapper">
                <div id="store-map" aria-label="Bản đồ các chi nhánh KD Restaurant"></div>
            </div>
            <div class="store-branch-list">
                <h4>Danh sách chi nhánh</h4>
                @if (Model.Branches?.Any() == true)
                {
                    <div class="branch-grid">
                        @foreach (var branch in Model.Branches)
                        {
                            var encodedAddress = Uri.EscapeDataString(branch.Address);
                            var encodedName = Uri.EscapeDataString(branch.Name);
                            <article class="branch-card" data-branch-id="@branch.Id">
                                <div class="d-flex justify-content-between align-items-start gap-2">
                                    <div>
                                        <h5 class="mb-1">@branch.Name</h5>
                                        <p class="branch-address mb-2">@branch.Address</p>
                                    </div>
                                    <span class="branch-distance" data-distance-label>-- km</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(branch.Description))
                                {
                                    <p class="branch-description">@branch.Description</p>
                                }
                                <div class="branch-card-actions">
                                    <a href="https://www.google.com/maps/search/?api=1&query=@encodedName%20@encodedAddress" target="_blank" rel="noopener">
                                        <i class="bi bi-map"></i> Xem bản đồ
                                    </a>
                                    @if (!string.IsNullOrWhiteSpace(branch.Phone))
                                    {
                                        <a href="tel:@branch.Phone">
                                            <i class="bi bi-telephone"></i> Gọi @branch.Phone
                                        </a>
                                    }
                                </div>
                            </article>
                        }
                    </div>
                }
                else
                {
                    <div class="store-empty-state">
                        <i class="bi bi-geo"></i> Hiện chưa có chi nhánh khả dụng để hiển thị.
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script id="store-branch-data" type="application/json">@Html.Raw(branchJson)</script>

@section Scripts {
    <script async defer src="https://maps.googleapis.com/maps/api/js?key=AIzaSyAl_iJC0m7qWNOFfVywnSUYL1VLSWh8ntk&callback=initStoreLocator"></script>
    <script>
        function initStoreLocator() {
            const branchDataElement = document.getElementById('store-branch-data');
            const rawBranchData = branchDataElement ? JSON.parse(branchDataElement.textContent || '[]') : [];
            const parseCoordinate = (value) => {
                if (value === null || value === undefined) {
                    return null;
                }
                if (typeof value === 'number') {
                    return Number.isFinite(value) ? value : null;
                }
                const parsed = parseFloat(value);
                return Number.isFinite(parsed) ? parsed : null;
            };
            const branchData = rawBranchData.map(branch => ({
                ...branch,
                latitude: parseCoordinate(branch.latitude),
                longitude: parseCoordinate(branch.longitude)
            }));
            const defaultLat = parseCoordinate('@Model.DefaultLatitude.ToString(System.Globalization.CultureInfo.InvariantCulture)') ?? 10.762622;
            const defaultLng = parseCoordinate('@Model.DefaultLongitude.ToString(System.Globalization.CultureInfo.InvariantCulture)') ?? 106.660172;
            const defaultCoords = { lat: defaultLat, lng: defaultLng };
            const alertBox = document.getElementById('store-alert');
            const statusText = document.getElementById('location-status');
            const useLocationBtn = document.getElementById('btn-use-location');
            const resetViewBtn = document.getElementById('btn-reset-view');
            const searchInput = document.getElementById('store-search-input');
            const searchBtn = document.getElementById('btn-search-address');
            const branchCards = document.querySelectorAll('.branch-card');

            const map = new google.maps.Map(document.getElementById('store-map'), {
                center: { lat: defaultCoords.lat, lng: defaultCoords.lng },
                zoom: 13,
                mapId: 'KD_STORE_LOCATOR'
            });

            const infoWindow = new google.maps.InfoWindow();

            const hasValidCoords = (branch) => Number.isFinite(branch.latitude) && Number.isFinite(branch.longitude);

            const state = {
                branchData,
                branchMarkers: new Map(),
                userMarker: null,
                userPosition: null
            };

            const showAlert = (message, type = 'info') => {
                if (!alertBox) return;
                alertBox.textContent = message;
                alertBox.className = 'store-alert';
                alertBox.classList.add('is-' + type);
                alertBox.style.display = 'block';
            };

            const clearAlert = () => {
                if (!alertBox) return;
                alertBox.style.display = 'none';
            };

            const setStatus = (text) => {
                if (!statusText) return;
                statusText.innerHTML = `<i class="bi bi-info-circle me-1"></i> ${text}`;
            };

            const toRadians = (deg) => deg * (Math.PI / 180);
            const distanceInKm = (lat1, lon1, lat2, lon2) => {
                const R = 6371;
                const dLat = toRadians(lat2 - lat1);
                const dLon = toRadians(lon2 - lon1);
                const a = Math.sin(dLat / 2) ** 2 + Math.cos(toRadians(lat1)) * Math.cos(toRadians(lat2)) * Math.sin(dLon / 2) ** 2;
                const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
                return R * c;
            };

            const addOrUpdateBranchMarker = (branch) => {
                if (!hasValidCoords(branch)) return;
                let marker = state.branchMarkers.get(branch.id);
                if (!marker) {
                    marker = new google.maps.Marker({
                        position: { lat: branch.latitude, lng: branch.longitude },
                        map,
                        title: branch.name
                    });
                    marker.addListener('click', () => {
                        infoWindow.setContent(`<strong>${branch.name}</strong><br/>${branch.address}`);
                        infoWindow.open({ anchor: marker, map });
                    });
                    state.branchMarkers.set(branch.id, marker);
                } else {
                    marker.setPosition({ lat: branch.latitude, lng: branch.longitude });
                }
            };

            const highlightNearestBranch = () => {
                if (!state.userPosition) {
                    branchCards.forEach(card => card.classList.remove('is-nearest'));
                    return;
                }
                let minDistance = Number.POSITIVE_INFINITY;
                let nearestId = null;
                state.branchData.forEach(branch => {
                    if (hasValidCoords(branch)) {
                        const distance = distanceInKm(state.userPosition.lat, state.userPosition.lng, branch.latitude, branch.longitude);
                        const label = document.querySelector(`.branch-card[data-branch-id="${branch.id}"] [data-distance-label]`);
                        if (label) {
                            label.textContent = `${distance.toFixed(1)} km`;
                        }
                        if (distance < minDistance) {
                            minDistance = distance;
                            nearestId = branch.id;
                        }
                    }
                });
                branchCards.forEach(card => {
                    const isNearest = Number(card.dataset.branchId) === nearestId;
                    card.classList.toggle('is-nearest', isNearest);
                });
                if (nearestId !== null && Number.isFinite(minDistance)) {
                    const nearest = state.branchData.find(b => b.id === nearestId);
                    setStatus(`Chi nhánh gần bạn nhất: <strong>${nearest?.name}</strong> (${minDistance.toFixed(1)} km).`);
                }
            };

            const panToBranch = (branchId) => {
                const branch = state.branchData.find(b => b.id === branchId);
                if (branch && hasValidCoords(branch)) {
                    map.panTo({ lat: branch.latitude, lng: branch.longitude });
                    map.setZoom(16);
                    const marker = state.branchMarkers.get(branchId);
                    if (marker) {
                        infoWindow.setContent(`<strong>${branch.name}</strong><br/>${branch.address}`);
                        infoWindow.open({ anchor: marker, map });
                    }
                }
            };

            const requestUserLocation = () => {
                clearAlert();
                if (!navigator.geolocation) {
                    showAlert('Trình duyệt của bạn không hỗ trợ định vị.', 'error');
                    return;
                }
                setStatus('Đang xin quyền truy cập vị trí...');
                navigator.geolocation.getCurrentPosition(position => {
                    state.userPosition = {
                        lat: position.coords.latitude,
                        lng: position.coords.longitude
                    };
                    if (!state.userMarker) {
                        state.userMarker = new google.maps.Marker({
                            position: state.userPosition,
                            map,
                            icon: {
                                url: 'https://cdn-icons-png.flaticon.com/512/684/684908.png',
                                scaledSize: new google.maps.Size(36, 36)
                            }
                        });
                    } else {
                        state.userMarker.setPosition(state.userPosition);
                    }
                    map.panTo(state.userPosition);
                    map.setZoom(15);
                    setStatus('Đã định vị bạn thành công.');
                    highlightNearestBranch();
                }, error => {
                    showAlert('Không thể truy cập vị trí: ' + error.message, 'error');
                    setStatus('Sử dụng vị trí mặc định: @Model.DefaultCityName.');
                }, { enableHighAccuracy: true, timeout: 12000 });
            };

            const resetView = () => {
                map.panTo({ lat: defaultCoords.lat, lng: defaultCoords.lng });
                map.setZoom(13);
                setStatus('Quay lại trung tâm thành phố @Model.DefaultCityName.');
                clearAlert();
            };

            const searchAddress = () => {
                const query = searchInput.value.trim();
                if (!query) {
                    showAlert('Vui lòng nhập địa chỉ muốn tìm.', 'info');
                    return;
                }
                const normalized = query.toLowerCase();
                const found = state.branchData.find(branch =>
                    (branch.name && branch.name.toLowerCase().includes(normalized)) ||
                    (branch.address && branch.address.toLowerCase().includes(normalized))
                );
                if (found && hasValidCoords(found)) {
                    panToBranch(found.id);
                    setStatus(`Đang hiển thị: ${found.name}.`);
                    clearAlert();
                }
                else {
                    showAlert('Không tìm thấy chi nhánh phù hợp hoặc thiếu tọa độ.', 'warning');
                }
            };

            branchCards.forEach(card => {
                card.addEventListener('click', () => panToBranch(Number(card.dataset.branchId)));
            });

            state.branchData.forEach(addOrUpdateBranchMarker);

            useLocationBtn?.addEventListener('click', requestUserLocation);
            resetViewBtn?.addEventListener('click', resetView);
            searchBtn?.addEventListener('click', searchAddress);
        }
    </script>
}
